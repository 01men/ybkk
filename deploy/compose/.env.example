# =============================================================================
# 元冰可可 AIOS — 部署配置示例
# =============================================================================
# 复制本文件为 .env 并填入真实值
#   cp .env.example .env
#   # 编辑 .env（install.sh 会自动生成随机密码）
# =============================================================================

# 部署时间
AIOS_VERSION=0.1.0
AIOS_DEPLOYED_AT=2026-07-08T00:00:00Z

# PostgreSQL
POSTGRES_DB=aios
POSTGRES_USER=aios
POSTGRES_PASSWORD=CHANGEME

# Neo4j
NEO4J_AUTH=neo4j/CHANGEME

# Redis（私有化内部网络，默认无密码）
REDIS_PASSWORD=

# MinIO
MINIO_ROOT_USER=aios
MINIO_ROOT_PASSWORD=CHANGEME

# JWT（必须 ≥ 32 字节随机）
JWT_SECRET=CHANGEME_AT_LEAST_32_BYTES_RANDOM
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=7

# KMS（本地轻量 KMS 密钥；生产环境建议外接 Vault）
AIOS_KMS_KEY=CHANGEME_64_HEX

# 控制台
AIOS_CONSOLE_PORT=8443
AIOS_API_PORT=8000

# LLM 网关
LLM_PROVIDER=qwen-local
LLM_QWEN_BASE_URL=http://qwen:8000
LLM_OPENAI_BASE_URL=
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_BASE_URL=
LLM_ANTHROPIC_API_KEY=

# 监控（启用 --profile monitoring 时使用）
GRAFANA_ADMIN_PASSWORD=CHANGEME

# 日志级别
LOG_LEVEL=INFO