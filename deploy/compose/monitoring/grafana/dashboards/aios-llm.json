{
  "title": "AIOS - LLM",
  "uid": "aios-llm",
  "panels": [
    {"id": 1, "type": "graph", "title": "LLM 调用速率（provider / model）",
     "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
     "targets": [{"expr": "sum by (provider, model) (rate(aios_llm_call_total[5m]))", "legendFormat": "{{provider}}/{{model}}"}]},
    {"id": 2, "type": "graph", "title": "LLM P95 延迟",
     "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
     "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(aios_llm_call_duration_seconds_bucket[5m])))", "legendFormat": "p95"}]},
    {"id": 3, "type": "graph", "title": "LLM 注入攻击拦截",
     "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
     "targets": [{"expr": "sum by (actor) (rate(aios_llm_injection_blocked_total[5m]))", "legendFormat": "{{actor}}"}]}
  ]
}
